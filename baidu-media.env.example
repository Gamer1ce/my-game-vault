# 复制为 data/baidu-media.env 后填写。该文件和授权令牌都不会上传 GitHub。
BAIDU_CLIENT_ID='百度开放平台应用的App Key'
BAIDU_CLIENT_SECRET='百度开放平台应用的Secret Key'

# 必须与百度开放平台后台登记的回调地址完全一致。
BAIDU_REDIRECT_URI='http://127.0.0.1:4174/callback'

# 要验证的百度网盘绝对路径。先用一个只含少量视频的目录测试。
BAIDU_MEDIA_FOLDER='/游戏精彩时刻'

# 可选：精确指定目录内用于验证的文件名；留空则选择列表中的第一个视频。
BAIDU_TEST_FILENAME=''

# 可选：填写公网网站的 HTTPS Origin，用于记录跨域响应头。
BAIDU_PLAYBACK_ORIGIN=''
