# 复制为 data/baidu-media.env 后填写。该文件和授权令牌都不会上传 GitHub。
# 设为 0 时停用百度云端线路，网站只展示并播放 Mac/外置硬盘中的媒体；改回 1 即可恢复。
BAIDU_MEDIA_ENABLED='1'
BAIDU_CLIENT_ID='百度开放平台应用的App Key'
BAIDU_CLIENT_SECRET='百度开放平台应用的Secret Key'

# 必须与百度开放平台后台登记的回调地址完全一致。
BAIDU_REDIRECT_URI='http://127.0.0.1:4174/callback'

# 要验证的百度网盘绝对路径。先用一个只含少量视频的目录测试。
BAIDU_MEDIA_FOLDER='/游戏精彩时刻'

# 可选：精确指定目录内用于验证的文件名；留空则选择列表中的第一个视频。
BAIDU_TEST_FILENAME=''

# 可选：填写公网网站的 HTTPS Origin，用于记录跨域响应头。
BAIDU_PLAYBACK_ORIGIN=''

# Cloudflare Worker部署后由脚本自动填写。代理密钥必须同时存在于本机与Worker Secret中。
BAIDU_PROXY_HOSTNAME='media.example.com'
BAIDU_PROXY_URL=''
BAIDU_PROXY_KEY=''

# 可选：中国访问优化线路。配置后网页会用256 KiB样本在两条线路间自动择优，并在当前会话复用结果。
# 阿里云 ESA 可与Cloudflare共用代理密钥，也可以使用独立的32字节base64url密钥。
BAIDU_PROXY_URL_CN=''
BAIDU_PROXY_KEY_CN=''
BAIDU_PROXY_TOKEN_TTL_SECONDS='600'
