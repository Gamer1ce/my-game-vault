{
  "name": "game-time-vault",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch server.mjs",
    "start": "node server.mjs",
    "media:sync": "node scripts/sync-remote-media.mjs",
    "media:baidu:authorize": "node --env-file-if-exists=data/baidu-media.env scripts/verify-baidu-media.mjs authorize",
    "media:baidu:verify": "node --env-file-if-exists=data/baidu-media.env scripts/verify-baidu-media.mjs verify",
    "media:faststart": "node scripts/optimize-highlight-mp4.mjs",
    "test": "node --test"
  },
  "engines": {
    "node": ">=22.5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@aws-sdk/lib-storage": "^3.1087.0",
    "@aws-sdk/s3-request-presigner": "^3.1087.0",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "multer": "^2.0.2",
    "nxapi": "^1.6.1-next.254",
    "psn-api": "^2.18.0",
    "undici": "^6.27.0"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
