# 复制为 data/remote-media.env 后填写。真实密钥文件已被 Git 忽略。
# 支持 AWS S3 以及提供 S3 兼容接口的对象存储。

# S3 兼容 API 地址。使用 AWS S3 时可以留空。
MEDIA_S3_ENDPOINT='https://你的S3接口地址'
MEDIA_S3_REGION='auto'
MEDIA_S3_BUCKET='你的存储桶名称'
MEDIA_S3_ACCESS_KEY_ID='你的Access Key'
MEDIA_S3_SECRET_ACCESS_KEY='你的Secret Key'

# 对象在存储桶内的目录前缀。
MEDIA_S3_PREFIX='highlights'

# 某些本地或兼容服务需要路径样式地址；通常保持0。
MEDIA_S3_FORCE_PATH_STYLE='0'

# 推荐留空：网站会生成30分钟有效的私有播放链接。
# 只有存储桶已配置公开CDN域名时才填写，例如 https://media.example.com
MEDIA_S3_PUBLIC_BASE_URL=''
MEDIA_SIGNED_URL_TTL_SECONDS='1800'
